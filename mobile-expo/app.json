{
  "expo": {
    "name": "Chayil SecureX",
    "slug": "chayil-securex",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "chayilsecurex",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#010507",
    "splash": {
      "backgroundColor": "#010507",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chayilsecurex.app"
    },
    "android": {
      "adaptiveIcon": { "backgroundColor": "#010507" },
      "package": "com.chayilsecurex.app"
    },
    "web": { "bundler": "metro", "output": "static" },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": { "typedRoutes": true }
  }
}
