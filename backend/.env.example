# ── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── PostgreSQL ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chayil_securex
DB_USER=chayil
DB_PASS=chayil_secret

# ── Redis (BullMQ queue) ─────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=24h

# ── Email (SMTP) ─────────────────────────────────────────
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SITE_EMAIL=info@chayilsecurex.com

# ── Threat Intel APIs ────────────────────────────────────
ABUSEIPDB_API_KEY=your_abuseipdb_key
VIRUSTOTAL_API_KEY=your_virustotal_key
SHODAN_API_KEY=your_shodan_key

# ── Feed URLs ────────────────────────────────────────────
FEED_URLS=https://feeds.feedburner.com/TheHackersNews,https://www.bleepingcomputer.com/feed/

# ── Docker ───────────────────────────────────────────────
DOCKER_SOCKET=/var/run/docker.sock
KALI_IMAGE=chayil/kali-tools:latest
SCAN_TIMEOUT=300
MAX_CONCURRENT_SCANS=5

# ── Security ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
SCAN_RATE_LIMIT_MAX=10
